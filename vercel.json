{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/nl",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/nl",
      "schedule": "30 7 * * 4"
    },
    {
      "path": "/api/cron/tic",
      "schedule": "0 2 18 * *"
    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  }
}