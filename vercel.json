{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/nl",
      "schedule": "0 0 * * *"
    },
    {
      "path": "/api/cron/nl",
      "schedule": "30 7 * * 4"
    },
    {
      "path": "/api/cron/tic",
      "schedule": "0 2 18 * *"
    },
    {
      "path": "/api/cron/dts",
      "schedule": "0 0 * * 1-5"
    },
    {
      "path": "/api/cron/qra",
      "schedule": "0 0 * * 1-5"
    }
  ]
}
