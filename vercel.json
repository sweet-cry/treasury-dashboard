{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python",
      "config": { "maxLambdaSize": "50mb" }
    }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "app.py" }
  ],
  "crons": [
    {
      "path": "/api/cron/all",
      "schedule": "30 0 * * *"
    },
    {
      "path": "/api/cron/nl",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/nl",
      "schedule": "30 20 * * 3"
    },
    {
      "path": "/api/cron/tic",
      "schedule": "0 2 18 * *"
    }
  ]
}
